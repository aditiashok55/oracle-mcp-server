# Oracle connection string in the format: username/password@host:port/service_name
ORACLE_CONNECTION_STRING=username/password@localhost:1521/XEPDB1

# Path to Oracle Instant Client directory (required on Windows, optional on Linux/macOS)
# Example on Windows: C:\Users\yourname\Downloads\instantclient_23_8
# Example on macOS:   /usr/local/lib/instantclient_23_8
ORACLE_INSTANT_CLIENT_PATH=